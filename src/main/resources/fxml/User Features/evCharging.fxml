<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="600" prefWidth="900" style="-fx-background-color: #0f0f1a; -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.EVChargingController">

    <!-- Top Nav Bar -->
    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color: #11101a; -fx-border-color: #1e1a2e; -fx-border-width: 0 0 1 0;                  -fx-padding: 14 24; -fx-pref-height: 60;">
        <Button onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #a29bfe;                        -fx-font-size: 12; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';                        -fx-border-width: 0; -fx-cursor: hand; -fx-padding: 6 10;" text="← Back" />
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label style="-fx-text-fill: white; -fx-background-color: #6c5ce7; -fx-background-radius: 8;                           -fx-padding: 6 12; -fx-font-size: 14; -fx-font-weight: bold;" text="SP" />
            <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="SmartPark" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill: #00cec9; -fx-font-size: 13; -fx-font-weight: bold;" text="⚡  EV Charging" />
    </HBox>

    <!-- Content Area -->
    <HBox VBox.vgrow="ALWAYS">

        <!-- Left Panel - EV Lookup -->
        <VBox prefWidth="360" spacing="0" style="-fx-background-color: #13101e; -fx-padding: 36;">

            <Label style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;                           -fx-padding: 0 0 14 0;" text="EV Lookup" />

            <Label style="-fx-text-fill: #c0c0d0; -fx-font-size: 12; -fx-padding: 0 0 4 0;" text="EV plate number" />
            <TextField fx:id="evPlateField" prefHeight="44" prefWidth="300" promptText="EV plate number" style="-fx-background-color: #0b0b14; -fx-text-fill: white;                               -fx-font-size: 13; -fx-background-radius: 8; -fx-padding: 10 14;                               -fx-border-color: rgba(108,92,231,0.3); -fx-border-radius: 8;                               -fx-border-width: 1; -fx-prompt-text-fill: #5a5a7a;                               " />

            <Region prefHeight="12" />

            <Button fx:id="loadBtn" onAction="#handleLoad" prefHeight="44" prefWidth="300" style="-fx-background-color: #00cec9; -fx-text-fill: #0f0f1a;                            -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8;                            -fx-cursor: hand; -fx-border-width: 0; -fx-letter-spacing: 0.3;" text="⚡   Load Charging Status" />

            <Region prefHeight="8" />

            <Label fx:id="errorLabel" style="-fx-text-fill: #e17055; -fx-font-size: 12;" />

            <Region prefHeight="20" />

            <HBox fx:id="modeBadge" managed="false" spacing="8" style="-fx-background-color: #1e2f40; -fx-background-radius: 10; -fx-padding: 12;" visible="false">

                <Label style="-fx-font-size: 18; -fx-text-fill: #00cec9;" text="⚡" />
                <VBox spacing="2">
                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 10;" text="Active Billing Mode" />
                    <Label fx:id="modeLabel" style="-fx-text-fill: #00cec9; -fx-font-size: 13; -fx-font-weight: bold;" />
                </VBox>
            </HBox>

            <Region prefHeight="10" />

            <VBox fx:id="rateCard" managed="false" spacing="6" style="-fx-background-color: #1e1a2e; -fx-background-radius: 10; -fx-padding: 14;" visible="false">

                <HBox spacing="6">
                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;" text="Rate / min:" />
                    <Label fx:id="ratePerMinLabel" style="-fx-text-fill: white; -fx-font-size: 13;" />
                </HBox>
                <HBox spacing="6">
                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;" text="Rate / %:" />
                    <Label fx:id="ratePerPctLabel" style="-fx-text-fill: white; -fx-font-size: 13;" />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- Right Panel - Status -->
        <VBox spacing="0" style="-fx-background-color: #0f0f1a; -fx-padding: 36;" HBox.hgrow="ALWAYS">

            <!-- Status Card -->
            <VBox fx:id="statusCard" managed="false" spacing="14" style="-fx-background-color: #13101e; -fx-background-radius: 16; -fx-padding: 24;" visible="false">

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefHeight="70" prefWidth="70" style="-fx-background-radius: 35;">
                        <Circle fill="#00cec9" opacity="0.15" radius="35" />
                        <Label style="-fx-font-size: 36; -fx-text-fill: white;" text="⚡" />
                    </StackPane>
                    <VBox spacing="4">
                        <Label fx:id="evPlateDisplay" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />
                        <Label fx:id="evOwnerLabel" style="-fx-text-fill: #a29bfe; -fx-font-size: 13;" />
                    </VBox>
                </HBox>

                <!-- Battery Progress -->
                <HBox spacing="12">
                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;" text="Battery on arrival:" />
                    <Label fx:id="batteryArrivalLabel" style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
                </HBox>

                <Label fx:id="currentBatteryLabel" style="-fx-text-fill: #00cec9; -fx-font-size: 18; -fx-font-weight: bold;" text="Current: ~  %" />

                <ProgressBar fx:id="batteryBar" prefHeight="18" prefWidth="300" progress="0.5" style="-fx-accent: #00cec9; -fx-background-color: #1e2f40;                                     -fx-background-radius: 9; " />

                <Separator style="-fx-background-color: rgba(108,92,231,0.2); -fx-pref-height: 1;" />

                <GridPane hgap="24" vgap="10">
                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;" text="⏱ Elapsed Time" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label fx:id="elapsedLabel" style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;" text="⏳ Est. Full Charge" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label fx:id="estFullLabel" style="-fx-text-fill: white; -fx-font-size: 13;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;" text="💰 Live Charge Fee" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label fx:id="liveFeeLabel" style="-fx-text-fill: #00cec9; -fx-font-size: 20; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <Separator style="-fx-background-color: rgba(108,92,231,0.2); -fx-pref-height: 1;" />

                <HBox alignment="CENTER">
                    <Button fx:id="refreshLiveBtn" onAction="#handleRefreshLive" prefHeight="38" prefWidth="260" style="-fx-background-color: transparent; -fx-text-fill: #00cec9;                                    -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8;                                    -fx-cursor: hand; -fx-border-color: #00cec9; -fx-border-radius: 8;                                    -fx-border-width: 1.2;" text="↻  Refresh Live Data" />
                </HBox>
            </VBox>

            <!-- Placeholder -->
            <VBox fx:id="placeholder" alignment="CENTER" spacing="10" VBox.vgrow="ALWAYS">
                <StackPane alignment="CENTER" prefHeight="90" prefWidth="90" style="-fx-background-color: rgba(0,206,201,0.08); -fx-background-radius: 45;">
                    <Label style="-fx-font-size: 44; -fx-text-fill: #00cec9; -fx-alignment: CENTER;" text="⚡" />
                </StackPane>
                <Label style="-fx-text-fill: #5a5a7a; -fx-font-size: 13; -fx-alignment: CENTER;                               -fx-text-alignment: CENTER;" text="Enter your EV plate&#10;to view charging status" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </HBox>

    <!-- Bottom Status Bar -->
    <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: rgba(255,255,255,0.02); -fx-background-radius: 0;                  -fx-padding: 10 24; -fx-border-color: #1e1a2e; -fx-border-width: 1 0 0 0;">
        <Label fx:id="statusLabel" style="-fx-text-fill: #6a6a8a; -fx-font-size: 11;" text="Ready" />
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill: #3a3a5a; -fx-font-size: 11;" text="Smart Park" />
    </HBox>

</VBox>
