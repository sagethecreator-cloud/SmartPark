<VBox prefHeight="720" prefWidth="1200" style="-fx-background-color: #0f0f1a; -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.SlotGridController">

    <!-- Top Nav Bar -->
    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color: #11101a; -fx-border-color: #1e1a2e; -fx-border-width: 0 0 1 0;                  -fx-padding: 16 28; -fx-pref-height: 68;">
        <Button onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #a29bfe;                        -fx-font-size: 12; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';                        -fx-border-width: 0; -fx-cursor: hand; -fx-padding: 6 10;" text="← Back" />
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label style="-fx-text-fill: white; -fx-background-color: #6c5ce7; -fx-background-radius: 8;                           -fx-padding: 6 12; -fx-font-size: 14; -fx-font-weight: bold;" text="SP" />
            <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="SmartPark" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 13; -fx-font-weight: bold;" text="🅿  Slot Grid" />
    </HBox>

    <!-- Toolbar / Filter Row -->
    <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #12121f; -fx-pref-height: 66; -fx-padding: 0 24;">

        <Label style="-fx-text-fill: #c0c0d0; -fx-font-size: 14;" text="Filter:" />

        <ToggleButton fx:id="filterAll" selected="true" style="-fx-background-color: #1e1a2e; -fx-text-fill: white;                              -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #2e2a42; -fx-border-radius: 8; -fx-border-width: 1;" text="⊞  All">
            <toggleGroup>
                <ToggleGroup fx:id="filterGroup" />
            </toggleGroup>
        </ToggleButton>

        <ToggleButton fx:id="filterCompact" style="-fx-background-color: #1e1a2e; -fx-text-fill: white;                              -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #2e2a42; -fx-border-radius: 8; -fx-border-width: 1;" text="🚗  Compact" toggleGroup="$filterGroup" />

        <ToggleButton fx:id="filterMotorcycle" style="-fx-background-color: #1e1a2e; -fx-text-fill: white;                              -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #2e2a42; -fx-border-radius: 8; -fx-border-width: 1;" text="🏍  Motorcycle" toggleGroup="$filterGroup" />

        <ToggleButton fx:id="filterLarge" style="-fx-background-color: #1e1a2e; -fx-text-fill: white;                              -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #2e2a42; -fx-border-radius: 8; -fx-border-width: 1;" text="🚐  Large" toggleGroup="$filterGroup" />

        <ToggleButton fx:id="filterEV" style="-fx-background-color: #1e1a2e; -fx-text-fill: white;                              -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #2e2a42; -fx-border-radius: 8; -fx-border-width: 1;" text="⚡  EV" toggleGroup="$filterGroup" />

        <Region HBox.hgrow="ALWAYS" />

        <Label fx:id="statsLabel" style="-fx-text-fill: #a29bfe; -fx-font-size: 14; -fx-font-weight: bold;" text="-- / -- Available" />

        <Button fx:id="refreshBtn" onAction="#handleRefresh" prefHeight="40" prefWidth="124" style="-fx-background-color: transparent; -fx-text-fill: white;                        -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #2e2a42; -fx-border-radius: 8; -fx-border-width: 1;" text="↻  Refresh" />
    </HBox>

    <!-- Legend Row -->
    <HBox alignment="CENTER_LEFT" spacing="28" style="-fx-background-color: #0f0f1a; -fx-pref-height: 44; -fx-padding: 8 24;">

        <!-- Free (Green) -->
        <HBox alignment="CENTER_LEFT" spacing="7" />

        <!-- Occupied (Red) -->
        <HBox alignment="CENTER_LEFT" spacing="7" />

        <!-- EV Slot (Teal accent) -->
        <HBox alignment="CENTER_LEFT" spacing="7" />

        <Region HBox.hgrow="ALWAYS" />

        <Label style="-fx-text-fill: #4a4a6a; -fx-font-size: 11;" text="Green = Free  ·  Red = Occupied" />
    </HBox>

