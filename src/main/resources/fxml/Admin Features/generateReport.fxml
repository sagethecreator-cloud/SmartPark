<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="650" prefWidth="1100" style="-fx-background-color: #0f0f1a;" stylesheets="@darktheme.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.GenerateReportController">

    <Circle fill="#6c5ce7" opacity="0.045" radius="220" translateX="-280" translateY="-160" />
    <Circle fill="#a29bfe" opacity="0.055" radius="160" translateX="320" translateY="220" />
    <Circle fill="#6c5ce7" opacity="0.07" radius="80" translateX="350" translateY="-210" />

    <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="0" style="-fx-background-color: transparent; -fx-padding: 28 40 20 40;">

        <!-- Brand Strip -->
        <HBox alignment="CENTER_LEFT" spacing="0">
            <Label style="-fx-text-fill: white;                           -fx-background-color: #6c5ce7;                           -fx-background-radius: 6;                           -fx-padding: 4 10;                           -fx-font-size: 12;                           -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI';" text="SP" />
            <Label style="-fx-text-fill: white;                           -fx-font-size: 16;                           -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI';                           -fx-padding: 0 0 0 10;" text="SmartPark" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnBack" onAction="#handleBack" prefHeight="32" style="-fx-background-color: transparent;                            -fx-text-fill: #a29bfe;                            -fx-font-size: 12;                            -fx-font-family: 'Segoe UI';                            -fx-font-weight: bold;                            -fx-background-radius: 8;                            -fx-border-color: #a29bfe;                            -fx-border-radius: 8;                            -fx-border-width: 1.2;                            -fx-padding: 0 16;                            -fx-cursor: hand;" text="← Back" />
        </HBox>

        <!-- Page Heading -->
        <Region prefHeight="20" />
        <VBox alignment="CENTER" maxWidth="Infinity" spacing="6">
            <HBox alignment="CENTER" spacing="12" />
            <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 26; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Generate Report" />
            <Label style="-fx-text-fill: #8888aa; -fx-font-size: 13; -fx-font-family: 'Segoe UI';" text="View parking statistics and export reports by period" />
        </VBox>

        <Region prefHeight="16" />

        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: rgba(28,22,50,0.82);                      -fx-background-radius: 14;                      -fx-padding: 12 18;                      -fx-border-color: rgba(108,92,231,0.45);                      -fx-border-width: 1.2;                      -fx-border-radius: 14;">
            <ToggleButton fx:id="btnDay" style="-fx-background-color: #6c5ce7;                                  -fx-text-fill: white;                                  -fx-font-size: 12;                                  -fx-font-weight: bold;                                  -fx-font-family: 'Segoe UI';                                  -fx-background-radius: 8;                                  -fx-padding: 6 18;                                  -fx-cursor: hand;                                  -fx-border-width: 0;                                  -fx-pref-width: 80;" text="Day" />
            <ToggleButton fx:id="btnWeek" style="-fx-background-color: rgba(108,92,231,0.2);                                  -fx-text-fill: #a29bfe;                                  -fx-font-size: 12;                                  -fx-font-weight: bold;                                  -fx-font-family: 'Segoe UI';                                  -fx-background-radius: 8;                                  -fx-padding: 6 18;                                  -fx-cursor: hand;                                  -fx-border-width: 0;                                  -fx-pref-width: 80;" text="Week" />
            <ToggleButton fx:id="btnMonth" style="-fx-background-color: rgba(108,92,231,0.2);                                  -fx-text-fill: #a29bfe;                                  -fx-font-size: 12;                                  -fx-font-weight: bold;                                  -fx-font-family: 'Segoe UI';                                  -fx-background-radius: 8;                                  -fx-padding: 6 18;                                  -fx-cursor: hand;                                  -fx-border-width: 0;                                  -fx-pref-width: 80;" text="Month" />
            <Label style="-fx-text-fill: #6a6a8a;                           -fx-font-size: 12;                           -fx-font-family: 'Segoe UI';                           -fx-padding: 0 4 0 12;" text="or" />
            <DatePicker fx:id="datePicker" prefHeight="34" prefWidth="160" style="-fx-background-color: rgba(28,22,50,0.95);                                -fx-background-radius: 8;                                -fx-border-color: rgba(108,92,231,0.6);                                -fx-border-radius: 8;                                -fx-border-width: 1.2;                                -fx-text-fill: white;                                -fx-font-size: 12;                                -fx-font-family: 'Segoe UI';                                -fx-control-inner-background: rgba(28,22,50,0.95);                                -fx-prompt-text-fill: #6a6a8a;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnGenerate" onAction="#handleGenerate" prefHeight="32" prefWidth="100" style="-fx-background-color: #6c5ce7;                            -fx-text-fill: white;                            -fx-font-size: 12;                            -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI';                            -fx-background-radius: 8;                            -fx-cursor: hand;                            -fx-border-width: 0;" text="Generate" />
            <Button fx:id="btnSave" onAction="#handleSave" prefHeight="32" prefWidth="80" style="-fx-background-color: rgba(108,92,231,0.2);                            -fx-text-fill: #a29bfe;                            -fx-font-size: 12;                            -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI';                            -fx-background-radius: 8;                            -fx-cursor: hand;                            -fx-border-width: 0;" text="Save" />
        </HBox>

        <Region prefHeight="16" />

        <HBox spacing="14" VBox.vgrow="NEVER">
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(28,22,50,0.82);                          -fx-background-radius: 14;                          -fx-padding: 18 10;                          -fx-border-color: rgba(108,92,231,0.45);                          -fx-border-width: 1.2;                          -fx-border-radius: 14;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 26; -fx-text-fill: #a29bfe;" text="🚗" />
                <Label fx:id="statVehicles" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="0" />
                <Label style="-fx-text-fill: #6a6a8a; -fx-font-size: 10; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="TOTAL VEHICLES" />
            </VBox>
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(28,22,50,0.82);                          -fx-background-radius: 14;                          -fx-padding: 18 10;                          -fx-border-color: rgba(108,92,231,0.45);                          -fx-border-width: 1.2;                          -fx-border-radius: 14;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 26; -fx-text-fill: #55efc4;" text="💰" />
                <Label fx:id="statEarnings" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Rs 0.00" />
                <Label style="-fx-text-fill: #6a6a8a; -fx-font-size: 10; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="EARNINGS" />
            </VBox>
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(28,22,50,0.82);                          -fx-background-radius: 14;                          -fx-padding: 18 10;                          -fx-border-color: rgba(108,92,231,0.45);                          -fx-border-width: 1.2;                          -fx-border-radius: 14;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 26; -fx-text-fill: #fdcb6e;" text="🅿" />
                <Label fx:id="statOccupied" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="0" />
                <Label style="-fx-text-fill: #6a6a8a; -fx-font-size: 10; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="OCCUPIED SLOTS" />
            </VBox>
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(28,22,50,0.82);                          -fx-background-radius: 14;                          -fx-padding: 18 10;                          -fx-border-color: rgba(108,92,231,0.45);                          -fx-border-width: 1.2;                          -fx-border-radius: 14;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 26; -fx-text-fill: #e84393;" text="⚡" />
                <Label fx:id="statEV" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="0" />
                <Label style="-fx-text-fill: #6a6a8a; -fx-font-size: 10; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="EV VEHICLES" />
            </VBox>
        </HBox>

        <Region prefHeight="14" />

        <!-- Report Preview Area with header -->
        <VBox spacing="0" style="-fx-background-color: rgba(28,22,50,0.82);                      -fx-background-radius: 14;                      -fx-border-color: rgba(108,92,231,0.45);                      -fx-border-width: 1.2;                      -fx-border-radius: 14;" VBox.vgrow="ALWAYS">
            <!-- Preview header bar -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 16; -fx-background-color: rgba(108,92,231,0.10); -fx-background-radius: 14 14 0 0;">
                <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 11; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="📄  REPORT PREVIEW" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" style="-fx-text-fill: #6a6a8a; -fx-font-size: 11; -fx-font-family: 'Segoe UI';" text="Ready" />
            </HBox>
            <TextArea fx:id="previewArea" editable="false" promptText="Select a period or date and click Generate to preview the report here..." style="-fx-background-color: transparent;                              -fx-text-fill: #c0c0d0;                              -fx-font-family: 'Consolas';                              -fx-font-size: 12;                              -fx-background-radius: 0 0 14 14;                              -fx-border-width: 0;                              -fx-control-inner-background: transparent;                              -fx-highlight-fill: #6c5ce7;                              -fx-padding: 14 16;" VBox.vgrow="ALWAYS" />
        </VBox>

        <Region prefHeight="12" />

        <!-- Footer -->
        <HBox alignment="CENTER" />

    </VBox>

</StackPane>
