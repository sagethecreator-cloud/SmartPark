<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<!-- EV Card Structure (built programmatically by controller): Each card is a StackPane containing: - Rectangle background (fill rgba(28,22,50,0.82), stroke rgba(108,92,231,0.45), stroke-width 1.2, arcWidth 16, prefWidth 820, prefHeight 160) - Rectangle top accent bar (height=3, fill #6c5ce7, translateY=-78.5) - HBox padding 16 20 spacing 20 alignment CENTER containing: LEFT COLUMN: icon stack (2 circles + "⚡"), slot id, status label CENTER COLUMN: vehicle/owner/mode row, battery bar row, metrics row RIGHT COLUMN: "Battery In" label + arrival % label + "on arrival" Controller iterates all slots, checks instanceof EV + isChargingRequested(), calculates elapsedMins, currentBattery, feeSoFar, and builds cards dynamically. -->

<StackPane prefHeight="580" prefWidth="900" style="-fx-background-color: #0f0f1a; -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.MonitorEVController">

    <Circle fill="#6c5ce7" opacity="0.045" radius="220" translateX="-280" translateY="-160" />
    <Circle fill="#a29bfe" opacity="0.055" radius="160" translateX="320" translateY="220" />
    <Circle fill="#6c5ce7" opacity="0.07" radius="80" translateX="350" translateY="-210" />

    <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="0" style="-fx-background-color: transparent; -fx-padding: 28 48 28 48;">

        <!-- Brand Strip -->
        <HBox alignment="CENTER_LEFT" spacing="0">
            <Label style="-fx-background-color: #6c5ce7; -fx-background-radius: 6;                           -fx-padding: 4 10; -fx-text-fill: white; -fx-font-size: 12;                           -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="SP" />
            <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 10;" text="SmartPark" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #5a5a7a; -fx-font-size: 11; -fx-font-family: 'Segoe UI';" text="Admin · EV Monitor" />
        </HBox>

        <!-- Page Heading -->
        <Region prefHeight="20" />
        <VBox alignment="CENTER" maxWidth="Infinity" spacing="10">
            <HBox alignment="CENTER" spacing="12" />
            <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 26; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="REAL-TIME EV MONITOR" />
            <Label style="-fx-text-fill: #8888aa; -fx-font-size: 13; -fx-font-family: 'Segoe UI';" text="Live charging status for all active EVs" />
        </VBox>

        <!-- Status Bar -->
        <Region prefHeight="16" />
        <HBox alignment="CENTER_LEFT" prefWidth="840" style="-fx-padding: 0 30;">
            <Label fx:id="evCountLabel" style="-fx-text-fill: #a29bfe; -fx-font-size: 13; -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI';" text="0 EVs Charging" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="refreshBtn" onAction="#refreshMonitor" prefHeight="32" prefWidth="110" style="-fx-background-color: #6c5ce7; -fx-text-fill: white;                            -fx-font-size: 12; -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                            -fx-cursor: hand; -fx-border-width: 0;" text="⟳  Refresh" />
        </HBox>

        <!-- Scroll Area -->
        <Region prefHeight="12" />
        <ScrollPane fx:id="evScrollPane" fitToWidth="true" prefHeight="310" prefWidth="880" style="-fx-background: transparent; -fx-background-color: transparent;                            -fx-border-width: 0; -fx-padding: 0;">
            <VBox fx:id="evCardsContainer" spacing="12" style="-fx-background-color: transparent; -fx-padding: 4 30 12 30;">

                <!-- Empty State -->
                <VBox fx:id="emptyStateBox" alignment="CENTER" prefHeight="260" spacing="14" VBox.vgrow="ALWAYS">
                    <StackPane>
                        <Circle fill="#6c5ce7" opacity="0.10" radius="52" />
                        <Circle fill="#6c5ce7" opacity="0.13" radius="42" />
                        <Label style="-fx-font-size: 38; -fx-text-fill: #6c5ce7; -fx-opacity: 0.5;" text="⚡" />
                    </StackPane>
                    <Label style="-fx-text-fill: #5a5a7a; -fx-font-size: 16; -fx-font-weight: bold;                                   -fx-font-family: 'Segoe UI';" text="No EVs Currently Charging" />
                    <Label style="-fx-text-fill: #3a3a5a; -fx-font-size: 12;                                   -fx-font-family: 'Segoe UI';" text="All active EV charging sessions will appear here automatically" />
                </VBox>

            </VBox>
        </ScrollPane>

        <Region VBox.vgrow="ALWAYS" />

        <!-- Bottom Action Bar -->
        <Region prefHeight="12" />
        <HBox alignment="CENTER">
            <Button fx:id="backBtn" onAction="#goBack" prefHeight="38" prefWidth="200" style="-fx-background-color: transparent; -fx-text-fill: #a29bfe;                            -fx-font-size: 13; -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                            -fx-cursor: hand;                            -fx-border-color: #a29bfe; -fx-border-radius: 8;                            -fx-border-width: 1.2;" text="← Back to Dashboard" />
        </HBox>

    </VBox>

</StackPane>
