<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<StackPane prefHeight="580" prefWidth="900" style="-fx-background-color: #0f0f1a; -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.EVChargingRatesController">

    <Circle fill="#6c5ce7" opacity="0.045" radius="220" translateX="-280" translateY="-160" />
    <Circle fill="#a29bfe" opacity="0.055" radius="160" translateX="320" translateY="220" />
    <Circle fill="#6c5ce7" opacity="0.07" radius="80" translateX="350" translateY="-210" />

    <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="0" style="-fx-background-color: transparent; -fx-padding: 28 48 28 48;">

        <!-- Brand Strip -->
        <HBox alignment="CENTER_LEFT" spacing="0">
            <Label style="-fx-background-color: #6c5ce7; -fx-background-radius: 6;                           -fx-padding: 4 10; -fx-text-fill: white; -fx-font-size: 12;                           -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="SP" />
            <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 10;" text="SmartPark" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #5a5a7a; -fx-font-size: 11; -fx-font-family: 'Segoe UI';" text="Admin · EV Charging Rates" />
        </HBox>

        <!-- Page Heading -->
        <Region prefHeight="28" />
        <VBox alignment="CENTER" maxWidth="Infinity" spacing="10">
            <HBox alignment="CENTER" spacing="12" />
            <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 26; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="EV CHARGING RATES" />
            <Label style="-fx-text-fill: #8888aa; -fx-font-size: 13; -fx-font-family: 'Segoe UI';" text="Configure charging rates and active billing mode" />
        </VBox>

        <!-- Dual Rate Cards -->
        <Region prefHeight="24" />
        <HBox alignment="CENTER" spacing="30.0">

            <!-- Card 1 - Per Minute -->
            <StackPane prefHeight="170" prefWidth="262">
                <Rectangle height="170" style="-fx-fill: rgba(28,22,50,0.82);                                   -fx-stroke: rgba(108,92,231,0.45);                                   -fx-stroke-width: 1.2;                                   -fx-arc-width: 20; -fx-arc-height: 20;" width="262" />
                <VBox alignment="CENTER" prefHeight="170" prefWidth="262" spacing="12" StackPane.alignment="CENTER">
                    <StackPane>
                        <Circle fill="#6c5ce7" opacity="0.18" radius="28" />
                        <Circle fill="#6c5ce7" opacity="0.22" radius="22" />
                        <Label style="-fx-font-size: 22; -fx-text-fill: white;" text="⏱" />
                    </StackPane>
                    <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;                                   -fx-font-family: 'Segoe UI';" text="Per Minute Rate" />
                    <TextField fx:id="perMinRateField" prefWidth="120" style="-fx-background-color: transparent; -fx-text-fill: white;                                       -fx-font-size: 20; -fx-font-weight: bold;                                       -fx-font-family: 'Segoe UI'; -fx-alignment: CENTER;                                       -fx-padding: 4 0;                                       -fx-border-color: transparent transparent #6c5ce7 transparent;                                       -fx-border-width: 0 0 1.5 0;" />
                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 11;                                   -fx-font-family: 'Segoe UI';" text="Rs / min" />
                </VBox>
            </StackPane>

            <!-- Card 2 - Per Percent -->
            <StackPane prefHeight="170" prefWidth="262">
                <Rectangle height="170" style="-fx-fill: rgba(28,22,50,0.82);                                   -fx-stroke: rgba(108,92,231,0.45);                                   -fx-stroke-width: 1.2;                                   -fx-arc-width: 20; -fx-arc-height: 20;" width="262" />
                <VBox alignment="CENTER" prefHeight="170" prefWidth="262" spacing="12" StackPane.alignment="CENTER">
                    <StackPane>
                        <Circle fill="#a29bfe" opacity="0.18" radius="28" />
                        <Circle fill="#a29bfe" opacity="0.22" radius="22" />
                        <Label style="-fx-font-size: 22; -fx-text-fill: white;" text="🔋" />
                    </StackPane>
                    <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;                                   -fx-font-family: 'Segoe UI';" text="Per Percent Rate" />
                    <TextField fx:id="perPercentRateField" prefWidth="120" style="-fx-background-color: transparent; -fx-text-fill: white;                                       -fx-font-size: 20; -fx-font-weight: bold;                                       -fx-font-family: 'Segoe UI'; -fx-alignment: CENTER;                                       -fx-padding: 4 0;                                       -fx-border-color: transparent transparent #a29bfe transparent;                                       -fx-border-width: 0 0 1.5 0;" />
                    <Label style="-fx-text-fill: #8888aa; -fx-font-size: 11;                                   -fx-font-family: 'Segoe UI';" text="Rs / %" />
                </VBox>
            </StackPane>
        </HBox>

        <!-- Mode Switcher Card (centered, same width as rate cards combined) -->
        <Region prefHeight="20" />
        <HBox alignment="CENTER">
            <StackPane prefHeight="80" prefWidth="554">
                <Rectangle height="80" style="-fx-fill: rgba(28,22,50,0.82);                                   -fx-stroke: rgba(108,92,231,0.45);                                   -fx-stroke-width: 1.2;                                   -fx-arc-width: 16; -fx-arc-height: 16;" width="554" />
                <HBox alignment="CENTER" prefHeight="80" prefWidth="554" spacing="0" style="-fx-padding: 0 24;">
                    <VBox alignment="CENTER_LEFT" spacing="3" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Active Charging Mode" />
                        <Label fx:id="currentModeLabel" style="-fx-text-fill: #a29bfe; -fx-font-size: 11; -fx-font-family: 'Segoe UI';" text="Current mode: Per Minute" />
                    </VBox>
                    <HBox alignment="CENTER" spacing="10">
                        <Button fx:id="perMinModeBtn" onAction="#switchToPerMin" prefHeight="34" prefWidth="120" style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-width: 0;" text="Per Minute" />
                        <Button fx:id="perPercentModeBtn" onAction="#switchToPerPercent" prefHeight="34" prefWidth="120" style="-fx-background-color: transparent; -fx-text-fill: #a29bfe; -fx-font-size: 12; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: #a29bfe; -fx-border-radius: 8; -fx-border-width: 1.2;" text="Per Percent" />
                    </HBox>
                </HBox>
            </StackPane>
        </HBox>

        <!-- Info Note -->
        <Region prefHeight="12" />
        <HBox alignment="CENTER">
            <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 11; -fx-font-style: italic; -fx-font-family: 'Segoe UI';" text="ℹ  Rates apply immediately after saving. Mode switch affects all future billing." />
        </HBox>

        <!-- Error Label -->
        <Region prefHeight="6" />
        <Label fx:id="evRateErrorLabel" managed="false" style="-fx-text-fill: #e17055; -fx-font-size: 11; -fx-alignment: CENTER; -fx-font-family: 'Segoe UI';" text="" visible="false" />

        <Region VBox.vgrow="ALWAYS" />

        <!-- Bottom Action Bar -->
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 12 0 0 0;">
            <Button fx:id="saveEvRates" onAction="#saveEvRates" prefHeight="42" prefWidth="180" style="-fx-background-color: #6c5ce7; -fx-text-fill: white;                            -fx-font-size: 13; -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                            -fx-cursor: hand; -fx-border-width: 0;" text="Save EV Rates" />
            <Button fx:id="backBtn" onAction="#goBack" prefHeight="42" prefWidth="130" style="-fx-background-color: transparent; -fx-text-fill: #a29bfe;                            -fx-font-size: 13; -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                            -fx-cursor: hand;                            -fx-border-color: #a29bfe; -fx-border-radius: 8;                            -fx-border-width: 1.2;" text="← Back" />
        </HBox>

    </VBox>

</StackPane>
