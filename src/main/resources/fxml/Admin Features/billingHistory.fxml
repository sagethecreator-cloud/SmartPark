<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<StackPane prefHeight="650" prefWidth="1100" style="-fx-background-color: #0f0f1a;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.BillingHistoryController">

    <Circle fill="#6c5ce7" opacity="0.045" radius="220" translateX="-280" translateY="-160" />
    <Circle fill="#a29bfe" opacity="0.055" radius="160" translateX="320" translateY="220" />
    <Circle fill="#6c5ce7" opacity="0.07" radius="80" translateX="350" translateY="-210" />

    <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="0" style="-fx-background-color: transparent; -fx-padding: 28 40 20 40;">

        <!-- Brand Strip -->
        <HBox alignment="CENTER_LEFT" spacing="0">
            <Label style="-fx-text-fill: white;                           -fx-background-color: #6c5ce7;                           -fx-background-radius: 6;                           -fx-padding: 4 10;                           -fx-font-size: 12;                           -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI';" text="SP" />
            <Label style="-fx-text-fill: white;                           -fx-font-size: 16;                           -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI';                           -fx-padding: 0 0 0 10;" text="SmartPark" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #5a5a7a; -fx-font-size: 11; -fx-font-family: 'Segoe UI';" text="Admin · Billing History" />
        </HBox>

        <!-- Page Heading -->
        <Region prefHeight="20" />
        <HBox alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="0" />
                <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 26; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Billing History" />
                <Label style="-fx-text-fill: #8888aa;                               -fx-font-size: 13;                               -fx-font-family: 'Segoe UI';" text="View, filter and export all billing transactions" />
            </VBox>
            <!-- Counter badge -->
            <StackPane>
                <Rectangle arcHeight="14" arcWidth="14" height="68" style="-fx-fill: rgba(28,22,50,0.82);                                   -fx-stroke: rgba(108,92,231,0.45);                                   -fx-stroke-width: 1.2;" width="160" />
                <VBox alignment="CENTER" prefHeight="68" prefWidth="160" spacing="2">
                    <Label fx:id="countLabel" style="-fx-text-fill: #a29bfe;                                   -fx-font-size: 26;                                   -fx-font-weight: bold;                                   -fx-font-family: 'Segoe UI';" text="0" />
                    <Label style="-fx-text-fill: #6a6a8a;                                   -fx-font-size: 10;                                   -fx-font-weight: bold;                                   -fx-font-family: 'Segoe UI';" text="TOTAL TRANSACTIONS" />
                </VBox>
            </StackPane>
        </HBox>

        <!-- Filter Bar -->
        <Region prefHeight="20" />
        <VBox spacing="10" style="-fx-background-color: rgba(28,22,50,0.82);                      -fx-background-radius: 14;                      -fx-padding: 14 18;                      -fx-border-color: rgba(108,92,231,0.45);                      -fx-border-width: 1.2;                      -fx-border-radius: 14;">

            <!-- Card row 1: Search + filters + buttons -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label style="-fx-text-fill: #6a6a8a; -fx-font-size: 14;" text="🔍" />
                <TextField fx:id="searchField" prefHeight="34" prefWidth="260" promptText="Search bill ID, plate, owner..." style="-fx-background-color: transparent;                                   -fx-text-fill: white;                                   -fx-font-size: 12;                                   -fx-font-family: 'Segoe UI';                                   -fx-background-radius: 0;                                   -fx-padding: 0 8;                                   -fx-border-color: transparent transparent rgba(108,92,231,0.4) transparent;                                   -fx-border-width: 0 0 1 0;                                   -fx-prompt-text-fill: #5a5a7a;" />
                <Region prefWidth="8" />
                <ComboBox fx:id="periodCombo" prefHeight="34" prefWidth="140" style="-fx-background-color: rgba(108,92,231,0.15);                                  -fx-border-color: rgba(108,92,231,0.4);                                  -fx-border-radius: 8;                                  -fx-background-radius: 8;                                  -fx-border-width: 1;" />
                <ComboBox fx:id="typeCombo" prefHeight="34" prefWidth="140" style="-fx-background-color: rgba(108,92,231,0.15);                                  -fx-border-color: rgba(108,92,231,0.4);                                  -fx-border-radius: 8;                                  -fx-background-radius: 8;                                  -fx-border-width: 1;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnBack" onAction="#handleBack" prefHeight="34" style="-fx-background-color: transparent;                                -fx-text-fill: #a29bfe;                                -fx-font-size: 12;                                -fx-font-weight: bold;                                -fx-font-family: 'Segoe UI';                                -fx-background-radius: 8;                                -fx-border-color: #a29bfe;                                -fx-border-radius: 8;                                -fx-border-width: 1.2;                                -fx-padding: 0 16;                                -fx-cursor: hand;" text="← Back" />
                <Button fx:id="btnExport" onAction="#handleExport" prefHeight="34" prefWidth="110" style="-fx-background-color: rgba(108,92,231,0.20);                                -fx-text-fill: #a29bfe;                                -fx-font-size: 12;                                -fx-font-weight: bold;                                -fx-font-family: 'Segoe UI';                                -fx-background-radius: 8;                                -fx-border-color: rgba(108,92,231,0.4);                                -fx-border-radius: 8;                                -fx-border-width: 1;                                -fx-cursor: hand;" text="📤  Export" />
                <Button fx:id="btnRefresh" onAction="#handleRefresh" prefHeight="34" prefWidth="110" style="-fx-background-color: #6c5ce7;                                -fx-text-fill: white;                                -fx-font-size: 12;                                -fx-font-weight: bold;                                -fx-font-family: 'Segoe UI';                                -fx-background-radius: 8;                                -fx-cursor: hand;                                -fx-border-width: 0;" text="⟳  Refresh" />
            </HBox>

            <!-- Card row 2: Amount sort + Total -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <ComboBox fx:id="amountCombo" prefHeight="34" prefWidth="180" style="-fx-background-color: rgba(108,92,231,0.15);                                  -fx-border-color: rgba(108,92,231,0.4);                                  -fx-border-radius: 8;                                  -fx-background-radius: 8;                                  -fx-border-width: 1;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="totalLabel" style="-fx-text-fill: #a29bfe;                               -fx-font-size: 13;                               -fx-font-weight: bold;                               -fx-font-family: 'Segoe UI';" text="Total: Rs 0.00" />
            </HBox>
        </VBox>

        <!-- Table -->
        <Region prefHeight="14" />
        <TableView fx:id="historyTable" style="-fx-background-color: rgba(28,22,50,0.82);                           -fx-background-radius: 14;                           -fx-border-color: rgba(108,92,231,0.45);                           -fx-border-radius: 14;                           -fx-border-width: 1.2;                           -fx-font-family: 'Segoe UI';                           -fx-control-inner-background: rgba(15,12,28,0.9);                           -fx-table-cell-border-color: rgba(108,92,231,0.10);                           -fx-selection-bar: rgba(108,92,231,0.30);                           -fx-selection-bar-non-focused: rgba(108,92,231,0.18);" stylesheets="@billingHistory.css" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colBillId" prefWidth="150" text="Bill ID" />
                <TableColumn fx:id="colVehicle" prefWidth="200" text="Vehicle" />
                <TableColumn fx:id="colDuration" prefWidth="110" text="Duration" />
                <TableColumn fx:id="colAmount" prefWidth="130" text="Amount" />
                <TableColumn fx:id="colPaymentTime" prefWidth="180" text="Payment Time" />
                <TableColumn fx:id="colExtra" prefWidth="130" text="Extra Charges" />
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="12">
                    <Label style="-fx-font-size: 36; -fx-opacity: 0.35;" text="📋" />
                    <Label style="-fx-text-fill: #5a5a7a;                                   -fx-font-size: 14;                                   -fx-font-weight: bold;                                   -fx-font-family: 'Segoe UI';" text="No billing records found" />
                    <Label style="-fx-text-fill: #3a3a5a;                                   -fx-font-size: 12;                                   -fx-font-family: 'Segoe UI';" text="Completed transactions will appear here" />
                </VBox>
            </placeholder>
        </TableView>

        <!-- Footer -->
        <Region prefHeight="12" />
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label fx:id="statusLabel" style="-fx-text-fill: #6a6a8a;                           -fx-font-size: 11;                           -fx-font-family: 'Segoe UI';" text="Ready" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

    </VBox>

</StackPane>
