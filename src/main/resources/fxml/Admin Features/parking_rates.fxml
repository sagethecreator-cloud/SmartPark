<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<StackPane prefHeight="580" prefWidth="900" style="-fx-background-color: #0f0f1a; -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.ParkingRatesController">

    <Circle fill="#6c5ce7" opacity="0.045" radius="220" translateX="-280" translateY="-160" />
    <Circle fill="#a29bfe" opacity="0.055" radius="160" translateX="320" translateY="220" />
    <Circle fill="#6c5ce7" opacity="0.07" radius="80" translateX="350" translateY="-210" />

    <VBox alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" spacing="25.0" style="-fx-background-color: transparent; -fx-padding: 28 48 28 48;">

        <!-- Brand Strip -->
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding: 0 0 0 0;">
            <Label style="-fx-background-color: #6c5ce7; -fx-background-radius: 6;                           -fx-padding: 4 10; -fx-text-fill: white; -fx-font-size: 12;                           -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="SP" />
            <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;                           -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 10;" text="SmartPark" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #5a5a7a; -fx-font-size: 11;                           -fx-font-family: 'Segoe UI';" text="Admin · Parking Rates" />
        </HBox>

        <!-- Page Heading -->
        <Region prefHeight="28" />
        <VBox alignment="CENTER" maxWidth="Infinity" spacing="10">
            <HBox alignment="CENTER" spacing="12" />
            <Label style="-fx-text-fill: #a29bfe; -fx-font-size: 26; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text=" Parking Rates Management" />
            <Label style="-fx-text-fill: #8888aa; -fx-font-size: 13;                           -fx-font-family: 'Segoe UI';" text="Set per-minute charge for each vehicle type" />
        </VBox>

        <Region prefHeight="28" />

        <!-- Rate Editor Rows -->
        <VBox alignment="CENTER" maxWidth="560" prefWidth="560" spacing="14">

            <VBox alignment="CENTER" maxWidth="560">
                <StackPane maxWidth="560" prefHeight="64" prefWidth="560">
                    <Rectangle height="64" style="-fx-fill: rgba(28,22,50,0.82);                                       -fx-stroke: rgba(108,92,231,0.45);                                       -fx-stroke-width: 1.2;                                       -fx-arc-width: 14; -fx-arc-height: 14;" width="560" />
                    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 20;" StackPane.alignment="CENTER_LEFT">
                        <StackPane>
                            <Circle fill="#6c5ce7" opacity="0.18" radius="22" />
                            <Circle fill="#6c5ce7" opacity="0.22" radius="18" />
                            <Label style="-fx-font-size: 16; -fx-text-fill: white;" text="🚗" />
                        </StackPane>
                        <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;                                       -fx-font-family: 'Segoe UI'; -fx-min-width: 110;" text="Car" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="carRateField" style="-fx-background-color: transparent; -fx-text-fill: white;                                           -fx-font-size: 14; -fx-font-family: 'Segoe UI';                                           -fx-alignment: CENTER_RIGHT; -fx-pref-width: 90;                                           -fx-padding: 4 8;                                           -fx-border-color: transparent transparent #6c5ce7 transparent;                                           -fx-border-width: 0 0 1.5 0;" />
                        <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;                                       -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 8;" text="Rs / min" />
                        <Button fx:id="saveCarRate" onAction="#saveCarRate" prefHeight="32" prefWidth="70" style="-fx-background-color: #6c5ce7; -fx-text-fill: white;                                        -fx-font-size: 12; -fx-font-weight: bold;                                        -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                                        -fx-cursor: hand; -fx-border-width: 0;" text="Save" />
                    </HBox>
                </StackPane>
                <Label fx:id="carRateError" managed="false" style="-fx-text-fill: #e17055; -fx-font-size: 11;                               -fx-font-family: 'Segoe UI'; -fx-padding: 4 0 0 20;" text="" visible="false" />
            </VBox>

            <VBox alignment="CENTER" maxWidth="560">
                <StackPane maxWidth="560" prefHeight="64" prefWidth="560">
                    <Rectangle height="64" style="-fx-fill: rgba(28,22,50,0.82);                                       -fx-stroke: rgba(108,92,231,0.45);                                       -fx-stroke-width: 1.2;                                       -fx-arc-width: 14; -fx-arc-height: 14;" width="560" />
                    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 20;" StackPane.alignment="CENTER_LEFT">
                        <StackPane>
                            <Circle fill="#6c5ce7" opacity="0.18" radius="22" />
                            <Circle fill="#6c5ce7" opacity="0.22" radius="18" />
                            <Label style="-fx-font-size: 16; -fx-text-fill: white;" text="🏍" />
                        </StackPane>
                        <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;                                       -fx-font-family: 'Segoe UI'; -fx-min-width: 110;" text="Bike" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="bikeRateField" style="-fx-background-color: transparent; -fx-text-fill: white;                                           -fx-font-size: 14; -fx-font-family: 'Segoe UI';                                           -fx-alignment: CENTER_RIGHT; -fx-pref-width: 90;                                           -fx-padding: 4 8;                                           -fx-border-color: transparent transparent #6c5ce7 transparent;                                           -fx-border-width: 0 0 1.5 0;" />
                        <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;                                       -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 8;" text="Rs / min" />
                        <Button fx:id="saveBikeRate" onAction="#saveBikeRate" prefHeight="32" prefWidth="70" style="-fx-background-color: #6c5ce7; -fx-text-fill: white;                                        -fx-font-size: 12; -fx-font-weight: bold;                                        -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                                        -fx-cursor: hand; -fx-border-width: 0;" text="Save" />
                    </HBox>
                </StackPane>
                <Label fx:id="bikeRateError" managed="false" style="-fx-text-fill: #e17055; -fx-font-size: 11;                               -fx-font-family: 'Segoe UI'; -fx-padding: 4 0 0 20;" text="" visible="false" />
            </VBox>

            <VBox alignment="CENTER" maxWidth="560">
                <StackPane maxWidth="560" prefHeight="64" prefWidth="560">
                    <Rectangle height="64" style="-fx-fill: rgba(28,22,50,0.82);                                       -fx-stroke: rgba(108,92,231,0.45);                                       -fx-stroke-width: 1.2;                                       -fx-arc-width: 14; -fx-arc-height: 14;" width="560" />
                    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 20;" StackPane.alignment="CENTER_LEFT">
                        <StackPane>
                            <Circle fill="#6c5ce7" opacity="0.18" radius="22" />
                            <Circle fill="#6c5ce7" opacity="0.22" radius="18" />
                            <Label style="-fx-font-size: 16; -fx-text-fill: white;" text="🚛" />
                        </StackPane>
                        <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;                                       -fx-font-family: 'Segoe UI'; -fx-min-width: 110;" text="Truck" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="truckRateField" style="-fx-background-color: transparent; -fx-text-fill: white;                                           -fx-font-size: 14; -fx-font-family: 'Segoe UI';                                           -fx-alignment: CENTER_RIGHT; -fx-pref-width: 90;                                           -fx-padding: 4 8;                                           -fx-border-color: transparent transparent #6c5ce7 transparent;                                           -fx-border-width: 0 0 1.5 0;" />
                        <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;                                       -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 8;" text="Rs / min" />
                        <Button fx:id="saveTruckRate" onAction="#saveTruckRate" prefHeight="32" prefWidth="70" style="-fx-background-color: #6c5ce7; -fx-text-fill: white;                                        -fx-font-size: 12; -fx-font-weight: bold;                                        -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                                        -fx-cursor: hand; -fx-border-width: 0;" text="Save" />
                    </HBox>
                </StackPane>
                <Label fx:id="truckRateError" managed="false" style="-fx-text-fill: #e17055; -fx-font-size: 11;                               -fx-font-family: 'Segoe UI'; -fx-padding: 4 0 0 20;" text="" visible="false" />
            </VBox>

            <VBox alignment="CENTER" maxWidth="560">
                <StackPane maxWidth="560" prefHeight="64" prefWidth="560">
                    <Rectangle height="64" style="-fx-fill: rgba(28,22,50,0.82);                                       -fx-stroke: rgba(108,92,231,0.45);                                       -fx-stroke-width: 1.2;                                       -fx-arc-width: 14; -fx-arc-height: 14;" width="560" />
                    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 20;" StackPane.alignment="CENTER_LEFT">
                        <StackPane>
                            <Circle fill="#6c5ce7" opacity="0.18" radius="22" />
                            <Circle fill="#6c5ce7" opacity="0.22" radius="18" />
                            <Label style="-fx-font-size: 16; -fx-text-fill: white;" text="⚡" />
                        </StackPane>
                        <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;                                       -fx-font-family: 'Segoe UI'; -fx-min-width: 110;" text="EV" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="evRateField" style="-fx-background-color: transparent; -fx-text-fill: white;                                           -fx-font-size: 14; -fx-font-family: 'Segoe UI';                                           -fx-alignment: CENTER_RIGHT; -fx-pref-width: 90;                                           -fx-padding: 4 8;                                           -fx-border-color: transparent transparent #6c5ce7 transparent;                                           -fx-border-width: 0 0 1.5 0;" />
                        <Label style="-fx-text-fill: #8888aa; -fx-font-size: 12;                                       -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 8;" text="Rs / min" />
                        <Button fx:id="saveEvRate" onAction="#saveEvRate" prefHeight="32" prefWidth="70" style="-fx-background-color: #6c5ce7; -fx-text-fill: white;                                        -fx-font-size: 12; -fx-font-weight: bold;                                        -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                                        -fx-cursor: hand; -fx-border-width: 0;" text="Save" />
                    </HBox>
                </StackPane>
                <Label fx:id="evRateError" managed="false" style="-fx-text-fill: #e17055; -fx-font-size: 11;                               -fx-font-family: 'Segoe UI'; -fx-padding: 4 0 0 20;" text="" visible="false" />
            </VBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <!-- Bottom Action Bar -->
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 16 0 0 0;">
            <Button fx:id="saveAllRates" onAction="#saveAllRates" prefHeight="42" prefWidth="180" style="-fx-background-color: #6c5ce7; -fx-text-fill: white;                            -fx-font-size: 13; -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                            -fx-cursor: hand; -fx-border-width: 0;" text="Save All Rates" />
            <Button fx:id="backBtn" onAction="#goBack" prefHeight="42" prefWidth="130" style="-fx-background-color: transparent; -fx-text-fill: #a29bfe;                            -fx-font-size: 13; -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI'; -fx-background-radius: 8;                            -fx-cursor: hand;                            -fx-border-color: #a29bfe; -fx-border-radius: 8;                            -fx-border-width: 1.2;" text="← Back" />
        </HBox>

    </VBox>

</StackPane>
