<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<HBox fillHeight="true" maxHeight="Infinity" maxWidth="Infinity" prefHeight="620" prefWidth="960" style="-fx-background-color: #0a0812;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.controllers.LoginController">


    <!-- LEFT PANEL - Brand panel (50% width) -->
    <StackPane maxHeight="Infinity" maxWidth="Infinity" prefWidth="480" style="-fx-background-color: linear-gradient(to bottom right, #1a0a2e 0%, #0d1b4b 45%, #0a1628 100%);" HBox.hgrow="ALWAYS">

        <!-- Decorative ring top right -->
        <Circle fill="transparent" opacity="0.08" radius="220" stroke="#6c5ce7" strokeWidth="1" translateX="160" translateY="-160" />

        <!-- Decorative ring bottom left -->
        <Circle fill="transparent" opacity="0.07" radius="180" stroke="#a29bfe" strokeWidth="1" translateX="-150" translateY="180" />

        <!-- Glow orb top right -->
        <Circle fill="#6c5ce7" opacity="0.10" radius="120" translateX="180" translateY="-170" />

        <!-- Glow orb bottom left -->
        <Circle fill="#0984e3" opacity="0.09" radius="100" translateX="-160" translateY="200" />

        <!-- Dots top left -->
        <Circle fill="#6c5ce7" opacity="0.50" radius="4" translateX="-140" translateY="-220" />
        <Circle fill="#a29bfe" opacity="0.40" radius="2" translateX="-110" translateY="-195" />
        <Circle fill="#6c5ce7" opacity="0.35" radius="3" translateX="-160" translateY="-190" />

        <!-- Dots bottom right -->
        <Circle fill="#0984e3" opacity="0.50" radius="4" translateX="160" translateY="220" />
        <Circle fill="#74b9ff" opacity="0.40" radius="2" translateX="135" translateY="240" />
        <Circle fill="#0984e3" opacity="0.35" radius="3" translateX="175" translateY="200" />

        <!-- Dark overlay - Region supports maxWidth/maxHeight, Rectangle does not -->
        <Region maxHeight="Infinity" maxWidth="Infinity" style="-fx-background-color: rgba(5,3,15,0.35);" />

        <!-- Brand content bottom left -->
        <VBox alignment="BOTTOM_LEFT" maxHeight="Infinity" maxWidth="Infinity" style="-fx-padding: 0 40 46 42;">

            <Label style="-fx-text-fill: white;                        -fx-background-color: #6c5ce7;                        -fx-background-radius: 7;                        -fx-padding: 5 12;                        -fx-font-size: 11;                        -fx-font-weight: bold;                        -fx-font-family: 'Segoe UI';" text="SP" />

            <Region prefHeight="12" />

            <Label style="-fx-text-fill: white;                        -fx-font-size: 32;                        -fx-font-weight: bold;                        -fx-font-family: 'Segoe UI';" text="SmartPark" />

            <Label style="-fx-text-fill: #a29bfe;                        -fx-font-size: 13;                        -fx-font-family: 'Segoe UI';" text="Parking Management System" />

            <Region prefHeight="14" />

            <!-- Fixed-width accent line - Rectangle with no maxWidth is fine -->
            <Rectangle height="1.5" opacity="0.85" style="-fx-fill: #6c5ce7;" width="46" />

            <Region prefHeight="12" />

        </VBox>

        <!-- Version pill top right -->
        <VBox alignment="TOP_RIGHT" maxHeight="Infinity" maxWidth="Infinity" style="-fx-padding: 22 24 0 0;">
            <Label style="-fx-text-fill: #a29bfe;                        -fx-background-color: rgba(108,92,231,0.12);                        -fx-background-radius: 20;                        -fx-border-color: rgba(108,92,231,0.25);                        -fx-border-radius: 20;                        -fx-border-width: 1;                        -fx-padding: 4 12;                        -fx-font-size: 10;                        -fx-font-family: 'Segoe UI';" text="v1.0" />
        </VBox>

    </StackPane>


    <!-- RIGHT PANEL - Login form (50% width) -->
    <VBox alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" prefWidth="480" style="-fx-background-color: #0f0d1c;                -fx-border-color: rgba(108,92,231,0.10);                -fx-border-width: 0 0 0 1;" HBox.hgrow="ALWAYS">

        <!-- Inner form capped at 380px width -->
        <VBox alignment="CENTER_LEFT" maxWidth="380" spacing="0">

            <Label style="-fx-text-fill: white;                        -fx-font-size: 26;                        -fx-font-weight: bold;                        -fx-font-family: 'Segoe UI';" text="Welcome back" />

            <Label style="-fx-text-fill: #55556e;                        -fx-font-size: 13;                        -fx-font-family: 'Segoe UI';                        -fx-padding: 5 0 0 0;" text="Sign in to your admin account" />

            <Region prefHeight="26" />

            <!-- Avatar row -->
            <HBox alignment="CENTER_LEFT" spacing="14">

                <StackPane prefHeight="50" prefWidth="50">
                    <Circle fill="#6c5ce7" opacity="0.13" radius="25" />
                    <Circle fill="transparent" opacity="0.30" radius="25" stroke="#6c5ce7" strokeWidth="1.2" />
                    <Label style="-fx-text-fill: white; -fx-font-size: 20;" text="👤" />
                </StackPane>

                   <VBox alignment="CENTER" spacing="3">
                    <Label style="-fx-text-fill: white;                                -fx-font-size: 15;                                -fx-font-weight: bold;                                -fx-font-family: 'Segoe UI';" text="Administrator" />
                </VBox>

            </HBox>

            <Region prefHeight="24" />

            <!-- Divider using Region - supports maxWidth unlike Rectangle -->
            <Region maxWidth="Infinity" prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.05);" />

            <Region prefHeight="24" />

            <Label style="-fx-text-fill: #888898;                        -fx-font-size: 10;                        -fx-font-weight: bold;                        -fx-font-family: 'Segoe UI';                        -fx-padding: 0 0 7 2;" text="USERNAME" />

            <TextField fx:id="usernameField" maxWidth="Infinity" prefHeight="46" promptText="Enter your username" style="-fx-background-color: #181530;                        -fx-text-fill: white;                        -fx-prompt-text-fill: #404060;                        -fx-background-radius: 10;                        -fx-border-color: #28234a;                        -fx-border-radius: 10;                        -fx-border-width: 1.2;                        -fx-font-size: 13;                        -fx-font-family: 'Segoe UI';                        -fx-padding: 0 14;" />

            <Region prefHeight="16" />

            <Label style="-fx-text-fill: #888898;                        -fx-font-size: 10;                        -fx-font-weight: bold;                        -fx-font-family: 'Segoe UI';                        -fx-padding: 0 0 7 2;" text="PASSWORD" />

            <PasswordField fx:id="passwordField" maxWidth="Infinity" prefHeight="46" promptText="Enter your password" style="-fx-background-color: #181530;                        -fx-text-fill: white;                        -fx-prompt-text-fill: #404060;                        -fx-background-radius: 10;                        -fx-border-color: #28234a;                        -fx-border-radius: 10;                        -fx-border-width: 1.2;                        -fx-font-size: 13;                        -fx-font-family: 'Segoe UI';                        -fx-padding: 0 14;" />

            <Region prefHeight="10" />

            <Label fx:id="errorLabel" style="-fx-text-fill: #e17055;                        -fx-font-size: 12;                        -fx-font-family: 'Segoe UI';                        -fx-padding: 2 0 0 2;" text="" />

            <Region prefHeight="20" />

            <HBox maxWidth="Infinity" spacing="12">

                <Button maxWidth="Infinity" onAction="#handleLogin" prefHeight="48" style="-fx-background-color: #6c5ce7;                            -fx-text-fill: white;                            -fx-font-size: 14;                            -fx-font-weight: bold;                            -fx-font-family: 'Segoe UI';                            -fx-background-radius: 10;                            -fx-cursor: hand;" text="Sign In" HBox.hgrow="ALWAYS" />

                <Button maxWidth="Infinity" onAction="#handleBack" prefHeight="48" style="-fx-background-color: transparent;                            -fx-text-fill: #7070a0;                            -fx-font-size: 13;                            -fx-font-family: 'Segoe UI';                            -fx-border-color: #28234a;                            -fx-border-radius: 10;                            -fx-background-radius: 10;                            -fx-border-width: 1.2;                            -fx-cursor: hand;" text="Back" HBox.hgrow="ALWAYS" />

            </HBox>

            <Region prefHeight="26" />

            <!-- Bottom divider -->
            <Region maxWidth="Infinity" prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.05);" />

            <Region prefHeight="18" />

            <!-- Footer -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Circle fill="#2e2e4a" radius="3" />
            </HBox>

        </VBox>

    </VBox>

</HBox>
